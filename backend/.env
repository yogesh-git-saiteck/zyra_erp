# NexusERP Backend Configuration
PORT=8080
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_erp
DB_USER=erp_admin
DB_PASSWORD=nexus_erp_2024

# JWT
JWT_SECRET=nexus-erp-secret-key-change-in-production-2024
JWT_EXPIRES_IN=24h

# Security
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# AI Features
AI_ENABLED=true

# App
APP_NAME=NexusERP
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD
